# Opção B (produção Vercel): URL pública da API no Railway — sem barra no final.
# Configure o mesmo valor em: Vercel → Settings → Environment Variables → VITE_API_URL
VITE_API_URL=https://sua-api.railway.app

# Desenvolvimento local: deixe VITE_API_URL vazio ou comente; o Vite faz proxy de /api → :8000
