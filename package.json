{
  "name": "reels-transcript",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"python -m uvicorn api:app --host 127.0.0.1 --port 8000\" \"npm run dev --prefix frontend\"",
    "dev:web": "npm run dev --prefix frontend",
    "dev:api": "python -m uvicorn api:app --host 127.0.0.1 --port 8000",
    "build": "npm run build --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
